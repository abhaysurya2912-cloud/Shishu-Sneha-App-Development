    <!-- Feeding Tips Descriptions -->
    <string name="desc_exclusive_breastfeeding">ಎದೆಹಾಲು ನಿಮ್ಮ ಮಗುವಿಗೆ ಪರಿಪೂರ್ಣ ಆಹಾರವಾಗಿದೆ. ಮಗು ಕೇಳಿದಾಗಲೆಲ್ಲಾ - ಪ್ರತಿ 2-3 ಗಂಟೆಗಳಿಗೊಮ್ಮೆ (ದಿನಕ್ಕೆ 8-12 ಬಾರಿ) ಹಾಲು ಉಣಿಸಿ. ಮೊದಲ 6 ತಿಂಗಳವರೆಗೆ ನೀರು ಅಥವಾ ಬೇರೆ ಯಾವುದೇ ಆಹಾರದ ಅಗತ್ಯವಿಲ್ಲ.</string>
    <string name="desc_breastfeeding_latch">ಮಗುವಿನ ಬಾಯಿ ಕೇವಲ ತೊಟ್ಟನ್ನು ಮಾತ್ರವಲ್ಲದೆ, ಅದರ ಸುತ್ತಲಿನ ಕಪ್ಪು ಭಾಗವನ್ನೂ (ಅರಿಯೊಲಾ) ಮುಚ್ಚಿದೆ ಎಂದು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ. ಸರಿಯಾಗಿ ಹಾಲು ಉಣಿಸುವುದು ನೋವುಂಟು ಮಾಡುವುದಿಲ್ಲ. ಒಂದು ವೇಳೆ ನೋವಾಗುತ್ತಿದ್ದರೆ, ನಿಧಾನವಾಗಿ ಬಿಡಿಸಿ ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ.</string>
    <string name="desc_night_feeding">ಹಾಲು ಉತ್ಪತ್ತಿಯಾಗಲು ರಾತ್ರಿ ವೇಳೆ ಹಾಲು ಉಣಿಸುವುದು ಮುಖ್ಯವಾಗಿದೆ. ರಾತ್ರಿಯಲ್ಲಿ ಹಾಲು ಉತ್ಪಾದಿಸುವ ಹಾರ್ಮೋನ್ (ಪ್ರೊಲ್ಯಾಕ್ಟಿನ್) ಮಟ್ಟವು ಹೆಚ್ಚಾಗಿರುತ್ತದೆ. ಅನುಕೂಲಕ್ಕಾಗಿ ಮಲಗಿಕೊಂಡು ಹಾಲು ಉಣಿಸಲು ಪ್ರಯತ್ನಿಸಿ.</string>
    <string name="desc_starting_solids">6 ತಿಂಗಳ ನಂತರ, ಮೃದುವಾದ ಆಹಾರಗಳನ್ನು ಪರಿಚಯಿಸಿ: ಅಕ್ಕಿ ಗಂಜಿ, ಬೇಳೆ ಸಾರು, ಬಾಳೆಹಣ್ಣು, ಬೇಯಿಸಿದ ತರಕಾರಿಗಳು. 1-2 ಚಮಚದೊಂದಿಗೆ ಪ್ರಾರಂಭಿಸಿ, ಕ್ರಮೇಣ ಹೆಚ್ಚಿಸಿ. ಎದೆಹಾಲು ಉಣಿಸುವುದನ್ನು ಮುಂದುವರಿಸಿ.</string>
    <string name="desc_foods_introduce">6-8 ತಿಂಗಳು: ಮೃದುವಾದ ಧಾನ್ಯಗಳು, ತರಕಾರಿಗಳು, ಹಣ್ಣುಗಳು\n8-10 ತಿಂಗಳು: ಚೆನ್ನಾಗಿ ಬೇಯಿಸಿದ ಮಾಂಸ, ಮೊಟ್ಟೆ, ಮೃದುವಾದ ಬೆರಳು ಆಹಾರಗಳು (finger foods)\n10-12 ತಿಂಗಳು: ಮನೆಯಲ್ಲಿ ತಯಾರಿಸಿದ ಮೃದುವಾದ ಆಹಾರಗಳು</string>
    <string name="desc_foods_avoid">❌ ಜೇನುತುಪ್ಪ (ಬೊಟುಲಿಸಮ್ ಅಪಾಯ)\n❌ ಮುಖ್ಯ ಪಾನೀಯವಾಗಿ ಹಸುವಿನ ಹಾಲು\n❌ ಹೆಚ್ಚುವರಿ ಉಪ್ಪು ಅಥವಾ ಸಕ್ಕರೆ\n❌ ಇಡೀ ಬೀಜಗಳು (ಗಂಟಲಿನಲ್ಲಿ ಸಿಕ್ಕಿಹಾಕಿಕೊಳ್ಳುವ ಅಪಾಯ)\n❌ ಹಸಿ ಮೊಟ್ಟೆ</string>
    <string name="desc_iron_rich_foods">ಮೆದುಳಿನ ಬೆಳವಣಿಗೆಗೆ ಕಬ್ಬಿಣದಂಶ ಬಹಳ ಮುಖ್ಯ. ಉತ್ತಮ ಮೂಲಗಳು: ಬೇಳೆಕಾಳುಗಳು, ಮಾಂಸ, ಕಬ್ಬಿಣದಂಶವಿರುವ ಧಾನ್ಯಗಳು, ಹಸಿರು ಎಲೆ ತರಕಾರಿಗಳು. ಹೀರಲ್ಪಡುವಿಕೆಯನ್ನು ಹೆಚ್ಚಿಸಲು ವಿಟಮಿನ್ ಸಿ ಆಹಾರಗಳೊಂದಿಗೆ (ಟೊಮ್ಯಾಟೊ, ನಿಂಬೆ) ನೀಡಿ.</string>
    <string name="desc_signs_hunger">ಆರಂಭಿಕ ಲಕ್ಷಣಗಳು: ಕೈಗಳನ್ನು ಚೀಪುವುದು, ತಲೆಯನ್ನು ಅಕ್ಕಪಕ್ಕ ತಿರುಗಿಸುವುದು\nಕೊನೆಯ ಲಕ್ಷಣಗಳು: ಅಳುವುದು ಹಸಿವಿನ ಕೊನೆಯ ಲಕ್ಷಣವಾಗಿದೆ - ಅಳುವ ಮೊದಲೇ ಹಾಲು ಉಣಿಸಲು ಪ್ರಯತ್ನಿಸಿ.</string>
    <string name="desc_vitamin_d">ಕೇವಲ ಎದೆಹಾಲು ಕುಡಿಯುವ ಮಗುವಿಗೆ, ಮೊದಲ ದಿನದಿಂದ ಪ್ರತಿದಿನ 400 IU ವಿಟಮಿನ್ ಡಿ ಹನಿಗಳನ್ನು ನೀಡಿ. ಸೂರ್ಯನ ಬೆಳಕು ಮಾತ್ರ ಯಾವಾಗಲೂ ಸಾಕಾಗುವುದಿಲ್ಲ.</string>
    <string name="desc_hydration_toddlers">12 ತಿಂಗಳ ನಂತರ, ಹಸುವಿನ ಹಾಲನ್ನು ಪರಿಚಯಿಸಿ (ದಿನಕ್ಕೆ 500-700 ಮಿಲಿ ಸೀಮಿತಗೊಳಿಸಿ). ನೀರು ಅತ್ಯುತ್ತಮ ಪಾನೀಯವಾಗಿದೆ. ಹಣ್ಣಿನ ರಸಗಳನ್ನು ತಪ್ಪಿಸಿ - ಅವುಗಳಲ್ಲಿ ಸಕ್ಕರೆ ಹೆಚ್ಚಿರುತ್ತದೆ ಮತ್ತು ಪೌಷ್ಟಿಕಾಂಶ ಕಡಿಮೆ ಇರುತ್ತದೆ.</string>

    <!-- General Feeding Tips -->
    <string name="gen_tip_doctor">🩺 ಮಗುವಿನ ತೂಕ ಹೆಚ್ಚಾಗದಿದ್ದರೆ ವೈದ್ಯರನ್ನು ಭೇಟಿ ಮಾಡಿ</string>
    <string name="gen_tip_force_feed">😴 ಮಲಗಿರುವ ಮಗುವಿಗೆ ಬಲವಂತವಾಗಿ ಆಹಾರ ನೀಡಬೇಡಿ</string>
    <string name="gen_tip_wash_hands">🧼 ಪ್ರತಿ ಬಾರಿ ಆಹಾರ ನೀಡುವ ಮೊದಲು ಕೈಗಳನ್ನು ತೊಳೆದುಕೊಳ್ಳಿ</string>
    <string name="gen_tip_diary">📝 ಮೊದಲ ತಿಂಗಳು ಆಹಾರ ನೀಡುವ ಸಮಯದ ವಿವರಗಳನ್ನು ಬರೆದಿಡಿ</string>
    <string name="gen_tip_instincts">💬 ನಿಮ್ಮ ಮನಸ್ಸಿನ ಮಾತನ್ನು ನಂಬಿ - ನಿಮ್ಮ ಮಗುವಿನ ಬಗ್ಗೆ ನಿಮಗೆ ಚೆನ್ನಾಗಿ ತಿಳಿದಿದೆ</string>
